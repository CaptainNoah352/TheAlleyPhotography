<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My HTML Games</title>
  <style>
    :root {
      --bg: #0f0f1a;
      --accent: #00ffcc;
      --card: #1a1a2e;
    }
    
    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: linear-gradient(135deg, #0f0f1a, #1a0033);
      color: #eee;
      min-height: 100vh;
    }

    header {
      text-align: center;
      padding: 2rem 1rem;
      background: rgba(0, 0, 0, 0.4);
      border-bottom: 2px solid var(--accent);
    }

    h1 {
      margin: 0;
      font-size: 2.8rem;
      background: linear-gradient(90deg, #00ffcc, #ff00cc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      color: #aaa;
      margin-top: 0.5rem;
      font-size: 1.1rem;
    }

    .container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .search-bar {
      width: 100%;
      max-width: 500px;
      margin: 0 auto 2rem;
      padding: 12px 20px;
      border-radius: 50px;
      border: none;
      background: rgba(255,255,255,0.1);
      color: white;
      font-size: 1.1rem;
    }

    .search-bar:focus {
      outline: none;
      box-shadow: 0 0 0 3px var(--accent);
    }

    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .game-card {
      background: var(--card);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(0, 255, 204, 0.1);
    }

    .game-card:hover {
      transform: translateY(-12px) scale(1.03);
      box-shadow: 0 20px 40px rgba(0, 255, 204, 0.2);
      border-color: var(--accent);
    }

    .game-thumbnail {
      height: 160px;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      position: relative;
      overflow: hidden;
    }

    .game-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .game-info {
      padding: 1.2rem;
    }

    .game-title {
      margin: 0 0 8px 0;
      font-size: 1.4rem;
      color: white;
    }

    .game-desc {
      color: #bbb;
      font-size: 0.95rem;
      margin-bottom: 1rem;
      line-height: 1.4;
    }

    .play-btn {
      background: var(--accent);
      color: #000;
      border: none;
      padding: 10px 24px;
      border-radius: 50px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s;
      width: 100%;
    }

    .play-btn:hover {
      background: #00ffaa;
      transform: scale(1.05);
    }

    .no-results {
      text-align: center;
      grid-column: 1 / -1;
      padding: 4rem;
      color: #777;
      font-size: 1.3rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: #666;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>🎮 My Games</h1>
    <p class="subtitle">Portable HTML Game Collection • Play Anywhere</p>
  </header>

  <div class="container">
    <input type="text" id="search" class="search-bar" placeholder="Search games..." autocomplete="off">

    <div class="games-grid" id="gamesGrid">
      <!-- Games will be added here by JavaScript -->
    </div>
  </div>

  <footer>
    Made for offline &amp; portable play • Add your games below
  </footer>

  <script>
    // ==================== ADD YOUR GAMES HERE ====================
    const games = [
      {
        id: 1,
        title: "Flappy Bird Clone",
        description: "Classic endless flyer. How high can you go?",
        thumbnail: "https://picsum.photos/id/1015/400/300", // Replace with your own screenshot
        url: "games/flappy-bird/index.html"   // ← Change this path
      },
      {
        id: 2,
        title: "Snake",
        description: "Retro snake game with modern visuals",
        thumbnail: "https://picsum.photos/id/106/400/300",
        url: "games/snake/index.html"
      },
      {
        id: 3,
        title: "Tic Tac Toe",
        description: "Unbeatable AI included",
        thumbnail: "https://picsum.photos/id/201/400/300",
        url: "games/tictactoe.html"
      },
      {
        id: 4,
        title: "2048",
        description: "Slide and merge to reach 2048!",
        thumbnail: "https://picsum.photos/id/237/400/300",
        url: "games/2048/index.html"
      },
      // Add more games here ↓
      // {
      //   id: 5,
      //   title: "Your Game Name",
      //   description: "Short description of the game",
      //   thumbnail: "path/to/screenshot.jpg",
      //   url: "games/your-game/index.html"
      // }
    ];

    // Render all games
    function renderGames(filteredGames) {
      const grid = document.getElementById('gamesGrid');
      grid.innerHTML = '';

      if (filteredGames.length === 0) {
        grid.innerHTML = `<div class="no-results">No games found 😢<br><br>Try a different search term.</div>`;
        return;
      }

      filteredGames.forEach(game => {
        const card = document.createElement('div');
        card.className = 'game-card';
        card.innerHTML = `
          <div class="game-thumbnail">
            <img src="${game.thumbnail}" alt="${game.title}" onerror="this.style.display='none'; this.parentElement.innerHTML = '🎮';">
          </div>
          <div class="game-info">
            <h3 class="game-title">${game.title}</h3>
            <p class="game-desc">${game.description}</p>
            <button class="play-btn" onclick="playGame('${game.url}')">▶ Play Now</button>
          </div>
        `;
        grid.appendChild(card);
      });
    }

    // Open game in a new tab or fullscreen
    window.playGame = function(url) {
      // Try to open in new tab first
      const win = window.open(url, '_blank');
      
      // Fallback: open in same tab if popup is blocked
      if (!win) {
        window.location.href = url;
      }
    };

    // Search functionality
    document.getElementById('search').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase().trim();
      
      const filtered = games.filter(game => 
        game.title.toLowerCase().includes(term) ||
        game.description.toLowerCase().includes(term)
      );
      
      renderGames(filtered);
    });

    // Initial render
    renderGames(games);

    // Keyboard shortcut: Press '/' to focus search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.getElementById('search') !== document.activeElement) {
        e.preventDefault();
        document.getElementById('search').focus();
      }
    });
  </script>
</body>
</html>
